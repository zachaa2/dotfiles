# Main sway config

### Variables
set $mod Mod4
set $left h
set $down j
set $up k
set $right l

set $term kitty
set $menu sh -c 'pgrep -x wofi >/dev/null 2>&1 && pkill -x wofi || exec wofi --show drun --style ~/.config/wofi/gruvbox-dark.css'
set $file_explorer nautilus
set $lock $HOME/.dotfiles/config/.config/sway/scripts/lock.sh

### Output configuration
output * bg /home/aaron/.dotfiles/assets/wallpapers/eon_duo_gruvbox.jpg fill
output eDP-1 resolution 2880x1800 position 0,0

### Appearance
gaps inner 8px
gaps outer 8px

default_border pixel 1px
default_floating_border pixel 1px

include ~/.config/sway/config.d/theme

### Idle configuration
exec_always --no-startup-id $HOME/.dotfiles/config/.config/sway/scripts/idle.sh

# Manual lock
bindsym --release $mod+Shift+Escape exec $lock

### Input configuration
input type:touchpad {
    natural_scroll enabled
}

### Modular sections
include ~/.config/sway/config.d/keybinds
include ~/.config/sway/config.d/layout

### Status bar
bar {
    swaybar_command waybar
}

include /etc/sway/config.d/*